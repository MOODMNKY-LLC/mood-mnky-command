# Flow-mnky — copy to .env.local and fill in values.
# Supabase: use NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY (or NEXT_PUBLIC_SUPABASE_ANON_KEY as alias).
# Flowise: required for chat and admin document-store features.

# Supabase (from `supabase status` when running locally)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Flowise (FLOWISE_BASE_URL from root .env.local is used as fallback if FLOWISE_HOST_URL unset)
FLOWISE_HOST_URL=
FLOWISE_API_KEY=
