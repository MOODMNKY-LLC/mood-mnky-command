# =============================================================================
# Hydaelyn — env template
# Copy to .env or .env.local and fill in values.
# When running from monorepo root (pnpm dev:hydaelyn / pnpm build), the root
# dotenv loads ../../.env.local and ../../.env. This file documents Hydaelyn-
# specific variables; you can keep them in the root .env.local or duplicate
# here for standalone runs.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional fallback for server-side only (lib/supabase/admin.ts)
# SUPABASE_URL=

# -----------------------------------------------------------------------------
# FFLogs (optional — enable Sign in with FFLogs, link character, reports)
# -----------------------------------------------------------------------------
# Create a client at https://www.fflogs.com/api/clients/
# Redirect URIs: http://localhost:3012/auth/fflogs/callback, https://<host>/auth/fflogs/callback
FFLOGS_CLIENT_ID=
FFLOGS_CLIENT_SECRET=
# Set to true to show FFLogs UI in production
# NEXT_PUBLIC_FFLOGS_ENABLED=true

# -----------------------------------------------------------------------------
# OpenAI (optional — report insights, ACT insights)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# Optional; defaults to gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Lodestone / XIVAPI (optional — character gear/job from Lodestone)
# -----------------------------------------------------------------------------
# XIVAPI_BASE_URL=https://xivapi.com
# XIVAPI_API_KEY=

# -----------------------------------------------------------------------------
# App URL (optional — overlay links, OAuth callbacks)
# -----------------------------------------------------------------------------
# Base URL for overlay links (dashboard/live). Defaults to request host if unset.
# NEXT_PUBLIC_HYDAELYN_URL=https://hydaelyn.example.com
# Used in FFLogs import callback when VERCEL_URL is not set.
# NEXT_PUBLIC_APP_URL=https://hydaelyn.example.com
