# ============================================================================
# Self-Hosted Supabase — Portal Connection Reference
# ============================================================================
# Use when SUPABASE_MODE=self_hosted. The Portal needs these vars to connect
# to your self-hosted Supabase instance.
#
# For full Supabase self-hosted stack configuration (secrets, URLs, Auth, etc.),
# see: ../temp/.env.example.supabase
#
# To run self-hosted Supabase: clone supabase/supabase, use docker/ from that repo.
# Documentation: https://supabase.com/docs/guides/self-hosting/docker
# ============================================================================

# --- Portal-facing vars (fill with your self-hosted Supabase values) ---
NEXT_PUBLIC_SUPABASE_MT_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_MT_ANON_KEY=eyJ...
SUPABASE_MT_SERVICE_ROLE_KEY=eyJ...

# --- Optional: Studio, DB, Storage ---
# SUPABASE_STUDIO_URL=http://localhost:8000/studio
# SUPABASE_DATABASE_URL=postgresql://postgres:...@your-host:5432/postgres
# SUPABASE_STORAGE_URL=http://localhost:8000/storage/v1/s3
# SUPABASE_STORAGE_ACCESS_KEY=
# SUPABASE_STORAGE_SECRET_KEY=
# SUPABASE_STORAGE_REGION=us-east-1
