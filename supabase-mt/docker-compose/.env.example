# ============================================================================
# MOOD MNKY Docker Compose - Comprehensive Environment Variables
# ============================================================================
# Copy to .env and update values. For local dev, copy .env.local.example to .env
# or run: ./scripts/start-local.sh
#
# Stack DB: Flowise and n8n use the stack's Postgres (service "postgres") only.
# Supabase vars below are for the Portal (auth/multitenancy), not for this stack.
# ============================================================================

# ============================================================================
# SUPABASE MODE (Portal only - auth and multitenancy; not used by Flowise/n8n)
# ============================================================================
# local      = use supabase start --workdir supabase-mt (values from supabase status)
# production = use Supabase Cloud (fill NEXT_PUBLIC_SUPABASE_MT_* below)
# self_hosted = use your self-hosted Supabase (see .env.supabase.example)
SUPABASE_MODE=local

# --- When SUPABASE_MODE=local (run: supabase start --workdir supabase-mt) ---
# Values from supabase status - update after each supabase start if ports change
NEXT_PUBLIC_SUPABASE_MT_URL=http://127.0.0.1:54522
NEXT_PUBLIC_SUPABASE_MT_ANON_KEY=your-anon-key-from-supabase-status
SUPABASE_MT_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-status
SUPABASE_STUDIO_URL=http://127.0.0.1:54525
SUPABASE_MAILPIT_URL=http://127.0.0.1:54526
SUPABASE_MCP_URL=http://127.0.0.1:54522/mcp
SUPABASE_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54502/postgres
SUPABASE_STORAGE_URL=http://127.0.0.1:54522/storage/v1/s3
SUPABASE_STORAGE_ACCESS_KEY=625729a08b95bf1b7ff351a663f3a23c
SUPABASE_STORAGE_SECRET_KEY=850181e4652dd023b7a98c58ae0d2d34bd487ee0cc3254aed6eda37307425907
SUPABASE_STORAGE_REGION=local

# --- When SUPABASE_MODE=production (uncomment and fill) ---
# NEXT_PUBLIC_SUPABASE_MT_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_MT_ANON_KEY=eyJ...
# SUPABASE_MT_SERVICE_ROLE_KEY=eyJ...

# --- When SUPABASE_MODE=self_hosted (see .env.supabase.example) ---
# NEXT_PUBLIC_SUPABASE_MT_URL=http://your-supabase-host:8000
# NEXT_PUBLIC_SUPABASE_MT_ANON_KEY=...
# SUPABASE_MT_SERVICE_ROLE_KEY=...

# --- Supabase Management API (for portal proxy, AI SQL) ---
# Create at: Supabase Dashboard → Account → Access Tokens
# SUPABASE_MANAGEMENT_API_TOKEN=

# ============================================================================
# DATABASE (PostgreSQL - for Flowise and n8n in this stack only; not Supabase)
# ============================================================================
POSTGRES_DB=mood_mnky
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password

# ============================================================================
# MINIO (S3-compatible object storage)
# ============================================================================
# Used by Flowise (optional) and n8n (optional binary data). Buckets created by
# minio-createbucket: FLOWISE_S3_BUCKET, N8N_S3_BUCKET.
# For MinIO AIStor (recommended for AI): use docker-compose.aistor.yml and a free
# license from https://www.min.io/download (AIStor Free). See README "MinIO vs AIStor".
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Bucket names (must match minio-createbucket; default: flowise-artifacts, n8n-binaries)
FLOWISE_S3_BUCKET=flowise-artifacts
N8N_S3_BUCKET=n8n-binaries

# ============================================================================
# FLOWISE AI PLATFORM
# ============================================================================

# --- Core ---
FLOWISE_DB_NAME=flowise
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=admin_password
FLOWISE_PORT=3000
FLOWISE_FILE_SIZE_LIMIT=50mb

# --- Storage (local | s3 | gcs | azure) ---
# Default local: no S3 needed. Set to s3 and configure below to use MinIO.
FLOWISE_STORAGE_TYPE=local
# FLOWISE_BLOB_STORAGE_PATH=/root/.flowise/storage

# --- S3 Storage (when FLOWISE_STORAGE_TYPE=s3) ---
# FLOWISE_S3_STORAGE_BUCKET_NAME=flowise
# FLOWISE_S3_STORAGE_ACCESS_KEY_ID=
# FLOWISE_S3_STORAGE_SECRET_ACCESS_KEY=
# FLOWISE_S3_STORAGE_REGION=us-east-1
# FLOWISE_S3_ENDPOINT_URL=
# FLOWISE_S3_FORCE_PATH_STYLE=false

# --- S3 / MinIO (this stack) ---
# When FLOWISE_STORAGE_TYPE=s3, use MinIO from this compose:
# FLOWISE_STORAGE_TYPE=s3
# FLOWISE_S3_BUCKET=flowise-artifacts
# FLOWISE_S3_STORAGE_BUCKET_NAME=flowise-artifacts
# FLOWISE_S3_ENDPOINT_URL=http://minio:9000
# FLOWISE_S3_FORCE_PATH_STYLE=true
# FLOWISE_S3_STORAGE_ACCESS_KEY_ID=${MINIO_ROOT_USER}
# FLOWISE_S3_STORAGE_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}

# --- GCS Storage (when FLOWISE_STORAGE_TYPE=gcs) ---
# FLOWISE_GOOGLE_CLOUD_STORAGE_CREDENTIAL=
# FLOWISE_GOOGLE_CLOUD_STORAGE_PROJ_ID=
# FLOWISE_GOOGLE_CLOUD_STORAGE_BUCKET_NAME=
# FLOWISE_GOOGLE_CLOUD_UNIFORM_BUCKET_ACCESS=true

# --- Azure Storage (when FLOWISE_STORAGE_TYPE=azure) ---
# FLOWISE_AZURE_BLOB_STORAGE_CONNECTION_STRING=
# FLOWISE_AZURE_BLOB_STORAGE_ACCOUNT_NAME=
# FLOWISE_AZURE_BLOB_STORAGE_ACCOUNT_KEY=
# FLOWISE_AZURE_BLOB_STORAGE_CONTAINER_NAME=

# --- Cache (Redis) ---
FLOWISE_CACHE_TYPE=redis
FLOWISE_CACHE_REDIS_URL=redis://:@redis:6379

# --- Security & Secrets ---
FLOWISE_SECRETKEY_STORAGE_TYPE=local
# FLOWISE_SECRETKEY_OVERWRITE=
# FLOWISE_JWT_AUTH_TOKEN_SECRET=
# FLOWISE_JWT_REFRESH_TOKEN_SECRET=
# FLOWISE_EXPRESS_SESSION_SECRET=
# FLOWISE_TOKEN_HASH_SECRET=

# --- CORS / Iframe ---
# FLOWISE_CORS_ORIGINS=http://localhost:3000,http://localhost:5678
# FLOWISE_IFRAME_ORIGINS=http://localhost:3000

# --- Queue (when MODE=queue) ---
# FLOWISE_MODE=queue
# FLOWISE_QUEUE_REDIS_URL=redis://:@redis:6379

# --- Logging ---
FLOWISE_DEBUG=false
FLOWISE_LOG_LEVEL=info

# --- Model config ---
# FLOWISE_MODEL_LIST_CONFIG_JSON=https://raw.githubusercontent.com/FlowiseAI/Flowise/main/packages/components/models.json

# ============================================================================
# N8N WORKFLOW AUTOMATION
# ============================================================================

# --- Core ---
N8N_DB_NAME=n8n
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# --- Authentication ---
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin_password

# --- Postgres (DB_POSTGRESDB_* set via compose) ---
# DB_POSTGRESDB_SCHEMA=public
# DB_POSTGRESDB_POOL_SIZE=2
# DB_POSTGRESDB_SSL_ENABLED=false
# DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED=true
# DB_TABLE_PREFIX=

# --- Queue (Redis) ---
QUEUE_TYPE=redis
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379
REDIS_HOST=redis
REDIS_PORT=6379

# --- Executions ---
EXECUTIONS_PROCESS=main
EXECUTIONS_TIMEOUT=3600
EXECUTIONS_MAX_TIMEOUT=86400
# EXECUTION_DATA_PRUNE_TIMEOUT=3600

# --- Binary Data ---
# BINARYDATA_MODE=default
# Default filesystem; set to s3 for production (queue mode + S3 recommended per stack doc).
# BINARYDATA_STORAGE_TYPE=filesystem
# BINARYDATA_STORAGE_PATH=/home/node/.n8n/binaryData

# --- Binary data (S3 / MinIO) ---
# When BINARYDATA_STORAGE_TYPE=s3, use MinIO from this compose:
# BINARYDATA_STORAGE_TYPE=s3
# BINARYDATA_S3_ENDPOINT=http://minio:9000
# BINARYDATA_S3_BUCKET=n8n-binaries
# BINARYDATA_S3_ACCESS_KEY_ID=${MINIO_ROOT_USER}
# BINARYDATA_S3_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
# BINARYDATA_S3_FORCE_PATH_STYLE=true

# --- Logging ---
LOG_LEVEL=info

# --- Ollama (profiles: cpu, agent, gpu-nvidia, gpu-amd) ---
# When using --profile cpu or --profile agent, n8n/Flowise can use local Ollama.
# Host format: host:port (inside compose: ollama-cpu:11434 or ollama-gpu-nvidia:11434).
OLLAMA_HOST=ollama-cpu:11434

# --- Qdrant (profile: agent) ---
# Vector store for RAG/agents when running --profile agent. Port 6333.
# QDRANT_URL=http://qdrant:6333

# ============================================================================
# PROFILE: supabase (Supabase-aware package)
# ============================================================================
# Same services as Core/Agent; .env includes Supabase MT URL/keys so the stack
# works with the Portal. Set SUPABASE_MODE and NEXT_PUBLIC_SUPABASE_MT_* above.
# Run: docker compose --profile cpu up -d  (or --profile agent) with these vars set.

# --- AI Assistant ---
# N8N_AI_ENABLED=false
# N8N_AI_ASSISTANT_PROVIDER=
# N8N_AI_ASSISTANT_API_KEY=

# --- Timezone ---
# GENERIC_TIMEZONE=UTC

# ============================================================================
# REDIS
# ============================================================================
REDIS_MEMORY_LIMIT=256mb
# REDIS_PASSWORD=
# REDIS_USERNAME=default

# ============================================================================
# APPLICATION KEYS (optional)
# ============================================================================
# OPENAI_API_KEY=
# FLOWISE_API_KEY=
# N8N_API_KEY=

# ============================================================================
# PRODUCTION RECOMMENDATIONS
# ============================================================================
# 1. Change all default passwords
# 2. Enable SSL/TLS (N8N_PROTOCOL=https)
# 3. Set strong encryption keys
# 4. Configure WEBHOOK_URL to production domain
# 5. Use external storage (S3/GCS) for Flowise
# 6. Seed tenant_app_instances with Flowise/n8n URLs for each tenant
# 7. For S3-backed runs: set MINIO_ROOT_USER/MINIO_ROOT_PASSWORD and bucket names;
#    MinIO API/console ports (9000, 9001) can be closed to host and accessed via reverse proxy.
# 8. Profiles: use --profile cpu (base + Ollama CPU), --profile agent (+ Qdrant), or
#    --profile gpu-nvidia / --profile gpu-amd for GPU. See README "Profiles and packages".
