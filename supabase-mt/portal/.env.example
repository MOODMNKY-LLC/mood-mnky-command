# =============================================================================
# Multi-Tenant Portal — Environment Variables
# =============================================================================
# Copy to .env.local and fill in values. The portal dev script loads from
# repo root (../../.env.local and ../../.env) via dotenv-cli; you can also
# place these in the root .env.local for shared use across apps.
#
# See docs/ENV-MULTITENANT-SUPABASE.md for MT Supabase setup.
# See docs/MULTITENANT-ONBOARDING.md for step-by-step provisioning.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase MT (Multi-Tenant) — Required
# -----------------------------------------------------------------------------
# MT project URL and keys. Get from Supabase Dashboard or `supabase status`
# when running locally: pnpm supabase-mt:start
NEXT_PUBLIC_SUPABASE_MT_URL=
NEXT_PUBLIC_SUPABASE_MT_ANON_KEY=
SUPABASE_MT_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Supabase Management API — Required for proxy and AI SQL
# -----------------------------------------------------------------------------
# Used by /api/supabase-proxy (Management API calls) and /api/ai/sql.
# Create at: Supabase Dashboard → Account → Access Tokens
SUPABASE_MANAGEMENT_API_TOKEN=

# -----------------------------------------------------------------------------
# OpenAI — Required for AI SQL feature
# -----------------------------------------------------------------------------
# Used by /api/ai/sql to generate SQL from natural language.
# Optional: set NEXT_PUBLIC_ENABLE_AI_QUERIES=true to show AI query UI.
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
# Enable AI-powered natural-language SQL in the SQL editor (default: false)
# NEXT_PUBLIC_ENABLE_AI_QUERIES=true

# -----------------------------------------------------------------------------
# URLs — Optional (have defaults)
# -----------------------------------------------------------------------------
# Main site URL for footer links (default: https://www.moodmnky.com)
# NEXT_PUBLIC_MAIN_APP_URL=https://www.moodmnky.com

# Docs URL for footer (default: NEXT_PUBLIC_MAIN_APP_URL/docs)
# NEXT_PUBLIC_DOCS_URL=https://www.moodmnky.com/docs

# -----------------------------------------------------------------------------
# Optional — MT project reference & backoffice
# -----------------------------------------------------------------------------
# For CI or Supabase CLI linking (e.g. supabase link --project-ref)
# SUPABASE_MT_PROJECT_REF=
#
# Project ref for the in-app backoffice (Database, Auth, Storage, Users, Secrets, Logs).
# Get from Supabase Dashboard URL: https://supabase.com/dashboard/project/<this-value>
# Required for Admin > Supabase backoffice. Management API token also required.
# NEXT_PUBLIC_SUPABASE_MT_PROJECT_REF=
